# ── 必填 ──

# MySQL 数据库连接字符串
DATABASE_URL=mysql://user:password@localhost:3306/course_content

# JWT Cookie 签名密钥（生成一个随机字符串）
JWT_SECRET=your-random-secret-here

# Manus Forge API 地址和密钥
BUILT_IN_FORGE_API_URL=https://forge.manus.im
BUILT_IN_FORGE_API_KEY=your-forge-api-key

# Manus OAuth 服务地址
OAUTH_SERVER_URL=https://oauth.manus.im

# OAuth 应用 ID
VITE_APP_ID=your-app-id

# OAuth 门户地址
VITE_OAUTH_PORTAL_URL=https://oauth.manus.im

# 项目所有者 OpenID（用于接收生成完成通知）
OWNER_OPEN_ID=your-open-id

# ── 可选 ──

# LLM 最大输出 token 数（默认 32768）
# LLM_MAX_TOKENS=32768

# LLM 思考预算 token 数（默认 4096）
# LLM_THINKING_BUDGET=4096
